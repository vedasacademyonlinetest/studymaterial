<style>
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;700&family=Playfair+Display:wght@700;900&display=swap');

  :root {
    --bg: #0d0f14;
    --surface: #14171f;
    --card: #1a1e2a;
    --border: #252a38;
    --accent: #e8a020;
    --accent2: #4fc3f7;
    --accent3: #81c784;
    --text: #e8e8f0;
    --muted: #8890a8;
    --olympiad: #e8a020;
    --jee-main: #4fc3f7;
    --jee-adv: #cf6679;
    --level1: #81c784;
    --level2: #ffb74d;
    --level3: #ef9a9a;
    --level4: #ce93d8;
    --level5: #f48fb1;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Crimson Pro', serif;
    background: var(--bg);
    color: var(--text);
    font-size: 17px;
    line-height: 1.7;
  }

  header {
    background: linear-gradient(135deg, #0a0c10 0%, #12172a 50%, #0d1018 100%);
    border-bottom: 2px solid var(--accent);
    padding: 36px 40px 28px;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(232,160,32,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--accent);
    letter-spacing: 0.02em;
  }
  header p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .container { max-width: 960px; margin: 0 auto; padding: 40px 24px 80px; }

  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: 6px;
  }
  .olympiad-label { background: rgba(232,160,32,0.15); color: var(--olympiad); }
  .jee-main-label { background: rgba(79,195,247,0.15); color: var(--jee-main); }
  .jee-adv-label  { background: rgba(207,102,121,0.15); color: var(--jee-adv); }

  .level-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    padding: 2px 8px;
    border-radius: 20px;
    display: inline-block;
    margin-left: 8px;
    vertical-align: middle;
  }
  .lv1 { background: rgba(129,199,132,0.15); color: var(--level1); }
  .lv2 { background: rgba(255,183,77,0.15); color: var(--level2); }
  .lv3 { background: rgba(239,154,154,0.15); color: var(--level3); }
  .lv4 { background: rgba(206,147,216,0.15); color: var(--level4); }
  .lv5 { background: rgba(244,143,177,0.15); color: var(--level5); }

  .q-block {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 24px 28px;
    margin-bottom: 28px;
    position: relative;
    transition: border-color 0.2s;
  }
  .q-block:hover { border-left-color: var(--accent2); }
  .q-block.jee-main  { border-left-color: var(--jee-main); }
  .q-block.jee-adv   { border-left-color: var(--jee-adv); }

  .q-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .q-text {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 16px;
  }

  .diagram-box {
    background: #fff;
    border-radius: 6px;
    padding: 16px;
    margin: 14px 0 18px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
    margin-top: 10px;
  }
  .option {
    font-size: 0.9rem;
    color: var(--muted);
    padding: 4px 0;
    border-bottom: 1px dashed rgba(255,255,255,0.06);
  }
  .option span { color: var(--accent2); font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; margin-right: 6px; }

  .chapter-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 40px 0 24px;
  }
  .chapter-divider h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    color: var(--accent);
    white-space: nowrap;
  }
  .chapter-divider hr { flex: 1; border: none; border-top: 1px solid var(--border); }

  svg text { font-family: 'JetBrains Mono', monospace; }
</style>
</head>
