<!-- Q2 -->
<div class="q-block">
  <div class="q-number">Q 2 &nbsp;<span class="section-label olympiad-label">Olympiad</span><span class="level-badge lv1">Level 1</span></div>
  <div class="q-text">
    Two masses m₁ and m₂ are attached to the end of a string which passes over a smooth pulley attached to the edge of an inclined plane. The angle of inclination of the plane is 30° and m₁ = 10 kg, m₂ = 5 kg. Find the acceleration of mass m₁.
  </div>
  <div class="diagram-box">
    <svg width="260" height="180" viewBox="0 0 260 180">
      <!-- inclined plane triangle -->
      <polygon points="20,160 220,160 220,30" fill="#e8f4fd" stroke="#1565c0" stroke-width="2"/>
      <!-- angle label -->
      <text x="42" y="155" fill="#1565c0" font-size="12">30°</text>
      <!-- m1 block on slope -->
      <rect x="120" y="85" width="36" height="30" rx="3" fill="#1976d2" stroke="#0d47a1" stroke-width="1.5" transform="rotate(-27,138,100)"/>
      <text x="130" y="104" fill="white" font-size="11" font-weight="bold">m₁</text>
      <!-- pulley at top-right corner -->
      <circle cx="220" cy="30" r="10" fill="#ffa726" stroke="#e65100" stroke-width="1.5"/>
      <!-- string from m1 over pulley -->
      <line x1="155" y1="90" x2="220" y2="30" stroke="#333" stroke-width="1.5" stroke-dasharray="4,2"/>
      <!-- string down from pulley -->
      <line x1="220" y1="40" x2="220" y2="100" stroke="#333" stroke-width="1.5"/>
      <!-- m2 hanging -->
      <rect x="206" y="100" width="28" height="24" rx="3" fill="#e53935" stroke="#b71c1c" stroke-width="1.5"/>
      <text x="213" y="116" fill="white" font-size="11" font-weight="bold">m₂</text>
      <!-- labels -->
      <text x="22" y="175" fill="#555" font-size="10">m₁=10 kg, m₂=5 kg, θ=30°</text>
    </svg>
  </div>
  <div class="options">
    <div class="option"><span>1)</span> 1 m/s²</div>
    <div class="option"><span>2)</span> 2 m/s²</div>
    <div class="option"><span>3)</span> 3 m/s²</div>
    <div class="option"><span>4)</span> zero</div>
  </div>
</div>

<!-- Q3 -->
<div class="q-block">
  <div class="q-number">Q 3 &nbsp;<span class="section-label olympiad-label">Olympiad</span><span class="level-badge lv1">Level 1</span></div>
  <div class="q-text">
    Body of mass m₁ sliding down on a smooth inclined plane as shown in figure. Then find the tension in the string. (m₁ = 10 kg, m₂ = 4 kg, g = 10 m/s²)
  </div>
  <div class="diagram-box">
    <svg width="280" height="190" viewBox="0 0 280 190">
      <!-- triangle -->
      <polygon points="20,170 230,170 230,40" fill="#e8f5e9" stroke="#2e7d32" stroke-width="2"/>
      <text x="42" y="163" fill="#2e7d32" font-size="12">30°</text>
      <!-- m1 on slope -->
      <rect x="115" y="90" width="38" height="30" rx="3" fill="#388e3c" stroke="#1b5e20" stroke-width="1.5" transform="rotate(-27,134,105)"/>
      <text x="125" y="109" fill="white" font-size="11" font-weight="bold">m₁</text>
      <!-- arrow a on slope -->
      <line x1="100" y1="88" x2="80" y2="100" stroke="#d32f2f" stroke-width="2" marker-end="url(#arr)"/>
      <text x="58" y="98" fill="#d32f2f" font-size="10">a</text>
      <!-- pulley -->
      <circle cx="230" cy="40" r="10" fill="#ffa726" stroke="#e65100" stroke-width="1.5"/>
      <!-- string -->
      <line x1="155" y1="96" x2="230" y2="40" stroke="#333" stroke-width="1.5" stroke-dasharray="4,2"/>
      <line x1="230" y1="50" x2="230" y2="115" stroke="#333" stroke-width="1.5"/>
      <text x="235" y="85" fill="#555" font-size="10">T</text>
      <!-- m2 -->
      <rect x="215" y="115" width="30" height="24" rx="3" fill="#e53935" stroke="#b71c1c" stroke-width="1.5"/>
      <text x="222" y="131" fill="white" font-size="11" font-weight="bold">m₂</text>
      <!-- arrow a down -->
      <line x1="230" y1="140" x2="230" y2="155" stroke="#d32f2f" stroke-width="2" marker-end="url(#arr)"/>
      <text x="235" y="153" fill="#d32f2f" font-size="10">a</text>
      <text x="20" y="185" fill="#555" font-size="10">m₁=10 kg, m₂=4 kg, θ=30°, g=10 m/s²</text>
      <defs>
        <marker id="arr" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
          <path d="M0,0 L6,3 L0,6 Z" fill="#d32f2f"/>
        </marker>
      </defs>
    </svg>
  </div>
  <div class="options">
    <div class="option"><span>1)</span> 100/7 N</div>
    <div class="option"><span>2)</span> 200/7 N</div>
    <div class="option"><span>3)</span> 30/7 N</div>
    <div class="option"><span>4)</span> 300/7 N</div>
  </div>
</div>

<!-- Q4 -->
<div class="q-block">
  <div class="q-number">Q 4 &nbsp;<span class="section-label olympiad-label">Olympiad</span><span class="level-badge lv1">Level 1</span></div>
  <div class="q-text">
    If the incline is given 1 in x (i.e., sinθ = 1/x), then find "Tanθ".
  </div>
  <div class="diagram-box">
    <svg width="220" height="140" viewBox="0 0 220 140">
      <polygon points="20,120 200,120 200,20" fill="#fff9c4" stroke="#f57f17" stroke-width="2"/>
      <!-- hypotenuse label -->
      <text x="85" y="58" fill="#e65100" font-size="11" transform="rotate(-27,110,70)">x (hyp)</text>
      <!-- vertical side -->
      <text x="205" y="75" fill="#1565c0" font-size="11">1</text>
      <!-- horizontal -->
      <text x="95" y="135" fill="#555" font-size="11">√(x²-1)</text>
      <!-- angle -->
      <text x="35" y="112" fill="#6a1a6a" font-size="11">θ</text>
      <text x="20" y="135" fill="#555" font-size="10">sin θ = 1/x</text>
    </svg>
  </div>
  <div class="options">
    <div class="option"><span>1)</span> 1/x</div>
    <div class="option"><span>2)</span> x/√(x²-1)</div>
    <div class="option"><span>3)</span> √(x²+1)/√(x²-1)</div>
    <div class="option"><span>4)</span> 1/√(x²-1)</div>
  </div>
</div>

