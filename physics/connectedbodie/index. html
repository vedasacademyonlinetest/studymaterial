<!-- Q5 -->
<div class="q-block jee-main">
  <div class="q-number">Q 5 &nbsp;<span class="section-label jee-main-label">JEE Main</span><span class="level-badge lv2">Level 2</span></div>
  <div class="q-text">
    Three bodies are connected as shown in the figure. Find the acceleration of the system.
    (m₁ = 5 kg, m₂ = 6 kg, m₃ = 2 kg, g = 10 m/s²)
  </div>
  <div class="diagram-box">
    <svg width="300" height="200" viewBox="0 0 300 200">
      <!-- incline -->
      <polygon points="20,175 200,175 200,50" fill="#e3f2fd" stroke="#1565c0" stroke-width="2"/>
      <text x="38" y="168" fill="#1565c0" font-size="12">30°</text>
      <!-- m2 on slope -->
      <rect x="105" y="103" width="36" height="28" rx="3" fill="#1976d2" stroke="#0d47a1" stroke-width="1.5" transform="rotate(-27,123,117)"/>
      <text x="113" y="120" fill="white" font-size="11" font-weight="bold">m₂</text>
      <!-- m1 on slope above m2 -->
      <rect x="140" y="75" width="34" height="27" rx="3" fill="#0288d1" stroke="#01579b" stroke-width="1.5" transform="rotate(-27,157,88)"/>
      <text x="148" y="92" fill="white" font-size="11" font-weight="bold">m₁</text>
      <!-- string between blocks on slope -->
      <line x1="142" y1="100" x2="128" y2="110" stroke="#333" stroke-width="1.5"/>
      <!-- pulley at top right -->
      <circle cx="200" cy="50" r="10" fill="#ffa726" stroke="#e65100" stroke-width="1.5"/>
      <!-- string from m1 over pulley -->
      <line x1="170" y1="78" x2="200" y2="50" stroke="#333" stroke-width="1.5" stroke-dasharray="3,2"/>
      <!-- string down from pulley -->
      <line x1="200" y1="60" x2="200" y2="125" stroke="#333" stroke-width="1.5"/>
      <text x="205" y="92" fill="#555" font-size="10">T</text>
      <!-- m3 hanging -->
      <rect x="185" y="125" width="30" height="24" rx="3" fill="#e53935" stroke="#b71c1c" stroke-width="1.5"/>
      <text x="192" y="141" fill="white" font-size="11" font-weight="bold">m₃</text>
      <!-- acceleration arrows -->
      <line x1="85" y1="130" x2="65" y2="143" stroke="#d32f2f" stroke-width="2" marker-end="url(#arr2)"/>
      <text x="50" y="140" fill="#d32f2f" font-size="10">a</text>
      <line x1="200" y1="150" x2="200" y2="165" stroke="#d32f2f" stroke-width="2" marker-end="url(#arr2)"/>
      <text x="205" y="163" fill="#d32f2f" font-size="10">a</text>
